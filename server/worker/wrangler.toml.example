name = "YOUR_WORKER_NAME"
main = "src/index.ts"
compatibility_date = "2025-01-01"

[vars]
TUNNEL_URL = "YOUR_TUNNEL_URL"

[[d1_databases]]
binding = "DB"
database_name = "cos-briefings"
database_id = "YOUR_D1_DATABASE_ID"

# Custom domain: YOUR_CUSTOM_DOMAIN
# Set up via Cloudflare dashboard: Workers & Pages → YOUR_WORKER_NAME → Custom Domains → Add
