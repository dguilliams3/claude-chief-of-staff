# ─── Required ────────────────────────────────────────────────────────────────
# Both are generated/set during `setup-instance` (Phase 2 and Phase 5).

# Bearer token for API authentication.
# Used by: local API (server/local), agent sync (agent/sync.ts), PWA login.
# Must match the Worker secret: `wrangler secret put COS_TOKEN`
COS_TOKEN=

# Public URL of your Cloudflare Worker (e.g., https://cos-api.your-domain.workers.dev).
# Used by: agent/sync.ts to push briefings to D1 after local generation.
# Set after first `wrangler deploy` in Phase 5.
COS_WORKER_URL=

# ─── Optional ────────────────────────────────────────────────────────────────

# Override local API port (default: 3141).
# The tunnel and npm start both respect this value.
# COS_PORT=3141

# Restrict CORS to a specific frontend origin (e.g., https://cos-dashboard.pages.dev).
# If unset, all origins are allowed. Applies to both local API and Worker.
# CORS_ORIGIN=
